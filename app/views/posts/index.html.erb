<div class="flex items-center justify-center min-h-screen">
      <div class="w-full max-w-sm md:w-[40%] bg-gray-100 p-6 rounded-lg space-y-8">
            <% @posts.each do |post| %>
                  <div class="bg-white p-6">
                        <%= image_tag post.user.photo if post.user.photo.attached? %>
                              <div class="flex justify-between items-center mb-2">
                                    <div class="font-bold text-xl">
                                          <%= post.user_email.split('@').first %>
                                    </div>

                                    <% if post.user == current_user %>
                                          <div class="flex items-center gap-2">
                                                <%= link_to edit_post_path(post.id), class: 'flex items-center gap-1 text-blue-600' do %>
                                                       <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487L19.5 7.125M10.582 16.07L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931a1.875 1.875 0 112.652 2.652L10.582 16.07z"/>
                                                      </svg>
                                                      <span></span>
                                                <% end %>

                                                <%= button_to post_path(post.id), method: :delete, class: 'flex items-center gap-1 text-red-600' do %>
                                                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                                                       </svg>
                                                      <span></span>
                                                <% end %>
                                          </div>
                                    <% end %>
                               </div>

                               <div class="items-center justify-center border border-gray-300 rounded-full px-3 py-1 shadow-sm focus-within:ring-2 focus-within:ring-blue-500 bg-white">
                                    <%= image_tag post.photo, class: 'w-full aspect-[4/3] object-cover mb-2 rounded' %>

                                    <%= post.description %>
                              </div>

                              <%= render partial: 'posts/upvotes/likes', locals: {post: post} %>

                              <h4 class="font-semibold mt-4 mb-1">Comments:</h4>
                              <%= turbo_frame_tag "comments_#{post.id}" do %>
                                    <% post.comments.each do |comment| %>
                                          <%= render partial: "posts/comments/postComment", locals: { comment: comment, post: post } %>
                                    <% end %>
                              <% end %>

                              <div class="mt-2">
                                    <%= simple_form_for Comment.new, url: post_comments_path(post), method: :post do |f| %>
                                    <div class="flex items-center justify-center border border-gray-300 rounded-full px-3 py-1 shadow-sm focus-within:ring-2 focus-within:ring-blue-500 bg-white">
                                          
                                          <%= f.input :text, label: false, placeholder: 'Add a comment...', input_html: {} %>

                                          <%= f.submit 'Post', 
                                                class: 'ml-2 bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-4 py-1.5 rounded-full' %>
                                    </div>
                                    <% end %>
                              </div>

                  </div>
            <% end %>
      </div>
</div>
