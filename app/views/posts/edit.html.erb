<h1 class="text-2xl mb-4 font-bold text-center">Edit Post</h1>

<div class="flex items-center justify-center min-h-screen">
  <div class="w-full md:w-[40%] bg-gray-100 p-6 rounded-lg shadow-lg">
    <%= simple_form_for @post do |f| %>
      <%= f.input :photo %>
      <%= f.input :description, input_html: { rows: 8 } %>
      <%= f.submit 'Update Post', class: 'text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800' %>
    <% end %>
  </div>
</div>
